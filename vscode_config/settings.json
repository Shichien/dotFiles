{
    // https://vscode.cool/
    // 这是一个好东西，里面存有一些关于 VSCode 的配置的技巧

    // 编辑器基础设置
    // 全局缩进设置
    "editor.autoIndent": "full",
    "editor.indentSize": "tabSize",
    "editor.tabSize": 4,
    "editor.fontSize": 14,
    "editor.insertSpaces": true, // 使用空格而非制表符

    // 格式化设置
    // "files.autoSave": "onWindowChange",
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.autoClosingBrackets": "beforeWhitespace",
    "editor.autoClosingQuotes": "beforeWhitespace",
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "files.autoSaveDelay": 10000,
    "files.autoSave": "afterDelay",

    // 字体相关设置
    "editor.fontFamily": "JetBrains Mono, Consolas, 'Courier New', monospace",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "files.autoGuessEncoding": true,

    // 编辑器显示设置
    "editor.editContext": false,
    "editor.suggest.filterGraceful": false,
    "editor.wordWrap": "on",
    "workbench.startupEditor": "none",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "SynthWave '84",
    "window.dialogStyle": "custom", // 窗口样式
    "window.confirmSaveUntitledWorkspace": false,

    // 设置为 false 可以关闭文件夹的紧凑模式
    "explorer.compactFolders": false,
    "git-graph.commitDetailsView.fileView.fileTree.compactFolders": false,
    "scm.compactFolders": false,

    // 光标和工作区平滑移动设置
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "smooth",
    "workbench.reduceMotion": "on",
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,

    // Double Line 插件
    "editor.lineNumbers": "relative", // 相对行号
    "editor.glyphMargin": true,

    // 杂项
    "editor.mouseWheelZoom": true, // 允许鼠标滚轮滑动控制字体大小
    "debug.showBreakpointsInOverviewRuler": true, // 展示断点位置
    "explorer.confirmDelete": false,
    "security.workspace.trust.untrustedFiles": "open",
    "explorer.confirmDragAndDrop": false,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "search.followSymlinks": false,

    // 代理设置
    "http.proxy": "http://127.0.0.1:7890",
    "http.proxyAuthorization": null,

    // Vim 编辑器设置
    "vim.useSystemClipboard": false,
    "vim.useCtrlKeys": false,
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },

    // Git 设置
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "never",
    "git.enableSmartCommit": true,
    "git.autorefresh": false,
    "git.blame.editorDecoration.enabled": true,

    // 拼写检查
    "cSpell.enabled": true,
    "cSpell.allowCompoundWords": true, // 允许 arraylength 之类的复合词
    "cSpell.ignoreWords": ["Deralive", "ECNU", "ecnu", "Shichien"],

    // CPH 算法竞赛设置
    // 最好的 Vscode C++ 竞赛向配置教程：https://www.bilibili.com/video/BV1fVxCeVE9q
    "cph.general.defaultLanguage": "cpp",
    "cph.general.useShortCodeForcesName": true,
    "cph.language.cpp.SubmissionCompiler": "GNU G++20 13.2 (64 bit, winlibs)",
    "cph.language.cpp.Args": "-std=c++20",
    "labuladong-leetcode.workspaceFolder": "C:\\Users\\26421\\.lcpr",
    "cph.language.cpp.Command": "clang++",

    // Code-Runner 设置
    "code-runner.executorMap": {
        "javascript": "node",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
        "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "zig": "zig run",
        // 将编译标准修改为 C++20
        "cpp": "cd $dir && clang++ -std=c++20 $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        // "cpp": "cd $dir && clang++ -fdiagnostics-color=always -g $fileName -o $workspaceRoot\\runner -lpthread && $workspaceRoot\\runner",
        "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "php": "php",
        "python": "python -u",
        "perl": "perl",
        "perl6": "perl6",
        "ruby": "ruby",
        "go": "go run",
        "lua": "lua",
        "groovy": "groovy",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "bat": "cmd /c",
        "shellscript": "bash",
        "fsharp": "fsi",
        "csharp": "scriptcs",
        "vbscript": "cscript //Nologo",
        "typescript": "ts-node",
        "coffeescript": "coffee",
        "scala": "scala",
        "swift": "swift",
        "julia": "julia",
        "crystal": "crystal",
        "ocaml": "ocaml",
        "r": "Rscript",
        "applescript": "osascript",
        "clojure": "lein exec",
        "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
        "racket": "racket",
        "scheme": "csi -script",
        "ahk": "autohotkey /Restart",
        "autoit": "autoit3",
        "dart": "dart",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        "haskell": "runghc",
        "nim": "nim compile --verbosity:0 --hints:off --run",
        "lisp": "sbcl --script",
        "kit": "kitc --run",
        "v": "v run",
        "sass": "sass --style expanded",
        "scss": "scss --style expanded",
        "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
        "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "sml": "cd $dir && sml $fileName",
        "mojo": "mojo run",
        "erlang": "escript",
        "spwn": "spwn build",
        "pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml",
        "gleam": "gleam run -m $fileNameWithoutExt"
    },

    // 让 Code-Runner 走终端，运行之前保存文件
    "code-runner.runInTerminal": true,
    "code-runner.saveAllFilesBeforeRun": true,
    "code-runner.saveFileBeforeRun": true,

    // Error Lens 高亮代码错误提示插件
    // https://github.com/usernamehw/vscode-error-lens/blob/master/docs/docs.md#errorlensfontsize
    "errorLens.enabledDiagnosticLevels": ["error", "warning", "info"],
    "errorLens.fontSize": "12px",
    "errorLens.margin": "100px",
    "errorLens.padding": "2px 0.5ch",
    "errorLens.borderRadius": "0.3em",
    "errorLens.messageBackgroundMode": "message",
    "errorLens.messageTemplate": "$severity $message",
    "errorLens.severityText": ["❌", "⚠", "ℹ", "📗"],
    "errorLens.statusBarColorsEnabled": true,
    "errorLens.enableOnDiffView": true,
    "errorLens.gutterIconsEnabled": true,
    "errorLens.gutterIconSet": "circle",
    "errorLens.decorations": {
        "errorMessage": {
            "textDecoration": ";border:1.2px dashed #e4545470;text-shadow:1px 1px 2px #e4545470;border-radius:0.3em;padding:0 0.5ch;"
        }
    },

    // 来源：https://www.bilibili.com/video/BV1Hd4y1o7CN
    // Path Intellisense 路径感知
    "typescript.suggest.paths": false,
    "javascript.suggest.paths": false,
    "path-intellisense.autoSlashAfterDirectory": false,

    // Code Snap 代码截图工具
    "codesnap.backgroundColor": "#A4B0BB",
    "codesnap.boxShadow": "rgba(0, 0, 0, 0.6) 5px 5px 15px 5px",

    // Prettier 设置
    // 此处是全局设置，可以进入 https://prettier.io/playground 进行单语言设置
    "prettier.semi": true, // 句尾是否填加分号
    "prettier.singleQuote": false, //是否使用单引号
    "prettier.trailingComma": "none", //禁止随时添加逗号
    "prettier.tabWidth": 4, //每行代码的限制长度
    "prettier.proseWrap": "never", // 文本换行
    "prettier.bracketSpacing": true,
    "prettier.useEditorConfig": false, // 在对象字面量的花括号内侧使用空格作为间隔（true: { foo: bar } false: {foo: bar}）
    "prettier.bracketSameLine": true,
    "prettier.endOfLine": "auto",

    // Latex 编辑设置
    "[latex]": {
        "editor.defaultFormatter": "James-Yu.latex-workshop"
    },
    "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": false,
    "latex-workshop.latex.autoBuild.run": "never",
    "latex-workshop.showContextMenu": true,
    "latex-workshop.intellisense.package.enabled": true,
    "latex-workshop.message.error.show": false,
    "latex-workshop.message.warning.show": false,
    // 用于 LateX 代码格式化，需要安装 Latexindent，地址：https://ctan.org/tex-archive/support/latexindent
    // 配置教程：https://github.com/James-Yu/LaTeX-Workshop/wiki/Format
    "latex-workshop.formatting.latex": "latexindent",
    "latex-workshop.formatting.latexindent.path": "latexindent",
    "latex-workshop.latex.tools": [
        {
            "name": "xelatex",
            "command": "xelatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOCFILE%"
            ]
        },
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOCFILE%"
            ]
        },
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-outdir=%OUTDIR%",
                "%DOCFILE%"
            ]
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": ["%DOCFILE%"]
        },
        {
            "name": "biber",
            "command": "biber",
            "args": ["%DOCFILE%"]
        },
        {
            "name": "latexindent",
            "command": "latexindent",
            "args": ["-c", "%DOCFILE_EXT%", "-y=defaultIndent: '    '", "-m"],
            "env": {}
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "XeLaTeX",
            "tools": ["xelatex"]
        },
        {
            "name": "PDFLaTeX",
            "tools": ["pdflatex"]
        },
        {
            "name": "BibTeX",
            "tools": ["bibtex"]
        },
        {
            "name": "LaTeXmk",
            "tools": ["latexmk"]
        },
        {
            "name": "xelatex -> bibtex -> xelatex*2",
            "tools": ["xelatex", "bibtex", "xelatex", "xelatex"]
        },
        {
            "name": "pdflatex -> bibtex -> pdflatex*2",
            "tools": ["pdflatex", "bibtex", "pdflatex", "pdflatex"]
        },
        {
            "name": "xelatex -> biber -> xelatex*2",
            "tools": ["xelatex", "biber", "xelatex", "xelatex"]
        }
    ],
    "latex-workshop.latex.clean.fileTypes": [
        "*.aux",
        "*.bbl",
        "*.blg",
        "*.idx",
        "*.ind",
        "*.lof",
        "*.lot",
        "*.out",
        "*.toc",
        "*.acn",
        "*.acr",
        "*.alg",
        "*.glg",
        "*.glo",
        "*.gls",
        "*.ist",
        "*.fls",
        "*.log",
        "*.synctex.gz",
        "*.fdb_latexmk"
    ],
    "latex-workshop.latex.autoClean.run": "onFailed",
    "latex-workshop.latex.recipe.default": "lastUsed",
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
    "latex-workshop.view.pdf.viewer": "tab",

    // Typst 编辑设置
    "[typst-code]": {
        "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?"
    },
    "tinymist.formatterMode": "typstyle",

    // AutoHotKey 编辑设置
    "AHK++.v1.file": {
        "interpreterPath": "C:/Program Files/AutoHotkey/v2/AutoHotkey64_UIA.exe",
        "helpPath": "C:/Program Files/AutoHotkey/v2/AutoHotkey.chm"
    },

    // Pylance - python 编辑优化
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.typeCheckingMode": "standard",
    "python.defaultInterpreterPath": "d:\\Python\\python.exe",
    "python.createEnvironment.trigger": "off",

    // 使用 Ruff 检查工具
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },

    // 基于 Clang 的 Cpp 配置
    "clangd.arguments": [
        "--query-driver=D:/llvm/bin/clang++.exe",
        "--header-insertion=never"
    ],
    "clangd.fallbackFlags": ["-std=c++20"],
    "clang-format.executable": "C:/Users/26421/.vscode/extensions/xaver.clang-format-1.9.0/clang-format",

    "[c]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": false,
        "editor.formatOnPaste": true,
        "editor.defaultFormatter": "xaver.clang-format"
    },
    // 让格式化工具走 4 缩进
    "[cpp]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": false,
        "editor.formatOnPaste": true,
        "editor.defaultFormatter": "xaver.clang-format"
    },

    // 若不适用 Clang，而使用 Microsoft 自带的：

    // Cpp 编译设置
    "clang.cxxflags": ["-std=c++11"],
    "clang.cflags": ["-std=c99"],
    "cmake.showOptionsMovedNotification": false,
    "cmake.configureOnOpen": true,
    "C_Cpp.default.compilerPath": "D:\\mingw64\\bin\\g++.exe",
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],

    // C++ 自动格式化操作
    "C_Cpp.formatting": "vcFormat",
    "C_Cpp.vcFormat.newLine.beforeElse": false,
    "C_Cpp.vcFormat.space.insertAfterSemicolon": true,
    "C_Cpp.vcFormat.indent.caseLabels": true,
    "C_Cpp.vcFormat.space.withinInitializerListBraces": false,
    "C_Cpp.vcFormat.newLine.beforeCatch": false,
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.type": "sameLine",
    "C_Cpp.vcFormat.indent.caseContentsWhenBlock": true,
    "C_Cpp.vcFormat.newLine.beforeWhileInDoWhile": true,
    "C_Cpp.vcFormat.space.beforeEmptySquareBrackets": true,
    "C_Cpp.vcFormat.indent.preserveWithinParentheses": true,
    "C_Cpp.vcFormat.indent.withinParentheses": "alignToParenthesis",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.updateDelay": 1000,
    "C_Cpp.codeAnalysis.clangTidy.args": [""],
    "C_Cpp.codeAnalysis.clangTidy.checks.enabled": ["clang-analyzer-*"],
    "C_Cpp.intelliSenseEngine": "disabled",

    // Json 文件格式
    "[json]": {
        "editor.tabSize": 4,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // Jsonc 文件格式
    "[jsonc]": {
        "editor.tabSize": 4,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // Markdown 文件格式
    "markdown.extension.list.indentationSize": "inherit",
    "markdown.extension.tableFormatter.normalizeIndentation": true,
    "markdownlint.config": {
        "MD004": false,
        "MD022": false,
        "MD026": false,
        "MD032": false,
        "MD036": false,
        "MD047": false
    },
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },

    // TypeScript 和 YAML 文件格式
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[csharp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },

    // Toml 文件格式
    "evenBetterToml.formatter.indentEntries": true,

    // HTML 格式缩进开启
    "html.format.indentInnerHtml": true,
    "explorer.confirmPasteNative": false,
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.svg": "default",
        "*.pdf": "latex-workshop-pdf-hook"
    },

    // 使用 PasteImage 自动填充
    "pasteImage.path": "${currentFileDir}/images/${currentFileNameWithoutExt}",
    "pasteImage.defaultName": "YMMDDHHmmss",
    "pasteImage.namePrefix": "img-",
    "pasteImage.insertPattern": "#figure(\n  image(\"${imageSyntaxPrefix}${imageFilePath}${imageSyntaxSuffix}\", width: 80%),\n  caption: \"\",\n)",

    // 工作区默认全信任
    "security.promptForLocalFileProtocolHandling": false,
    "security.promptForRemoteFileProtocolHandling": false,
    "security.restrictUNCAccess": false,

    // Copilot 设置
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },

    // SSH
    "workbench.activityBar.location": "top",
    "remote.SSH.remotePlatform": {
        "deralive.top": "linux",
        "connect.bjb2.seetacloud.com": "linux",
        "connect.bjb1.seetacloud.com": "linux"
    },

    // JavaScript 和 TypeScript 设置
    "typescript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnPaste.enabled": false,
    "javascript.updateImportsOnPaste.enabled": false,

    // SVG 设置
    "svg.preview.mode": "svg",

    // Terminal 设置
    "terminal.integrated.stickyScroll.enabled": false,
    "terminal.integrated.commandsToSkipShell": ["matlab.interrupt"],
    "terminal.integrated.initialHint": false,

    // Live Server 设置
    "liveServer.settings.donotShowInfoMsg": true,
    "[toml]": {
        "editor.defaultFormatter": "tamasfe.even-better-toml"
    },

    // Agent
    "chat.viewSessions.orientation": "stacked",
    "chat.agent.maxRequests": 200,
    "diffEditor.maxComputationTime": 0

    // 修改光标颜色
    // "workbench.colorCustomizations": {
    //     "editorCursor.foreground": "#FF0000",
    //     "terminalCursor.foreground": "#FF0000"
    // }
}

// 常用的快捷键
// 使用 Ctrl + Tab 在多个窗口之间进行切换
// 使用 Alt + Right / Left 对光标所处的上一个位置进行切换
// 使用 Ctrl + Alt + Right / Left 将当前正在编辑的窗口移动到左侧或右侧
// 使用 Ctrl + Alt + V 来粘贴图片

